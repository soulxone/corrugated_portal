{
    "name": "Quote Request",
    "doctype": "DocType",
    "module": "Corrugated Portal",
    "autoname": "QR-.YYYY.-.#####",
    "is_submittable": 1,
    "editable_grid": 1,
    "engine": "InnoDB",
    "fields": [
        {
            "fieldname": "request_number",
            "fieldtype": "Data",
            "label": "Request Number",
            "read_only": 1,
            "in_list_view": 0
        },
        {
            "fieldname": "customer",
            "fieldtype": "Link",
            "label": "Customer",
            "options": "Customer",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "contact_name",
            "fieldtype": "Data",
            "label": "Contact Name"
        },
        {
            "fieldname": "contact_email",
            "fieldtype": "Data",
            "label": "Contact Email",
            "options": "Email"
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "New\nUnder Review\nQuoted\nAccepted\nDeclined",
            "default": "New",
            "in_list_view": 1,
            "allow_on_submit": 1
        },
        {
            "fieldname": "section_box_spec",
            "fieldtype": "Section Break",
            "label": "Box Specification"
        },
        {
            "fieldname": "box_style",
            "fieldtype": "Select",
            "label": "Box Style",
            "options": "RSC\nFOL\nHSC\nTRAY\nBLISS\nDIE-CUT\nOther",
            "reqd": 1
        },
        {
            "fieldname": "length",
            "fieldtype": "Float",
            "label": "Length (in)",
            "precision": 4
        },
        {
            "fieldname": "width",
            "fieldtype": "Float",
            "label": "Width (in)",
            "precision": 4
        },
        {
            "fieldname": "depth",
            "fieldtype": "Float",
            "label": "Depth (in)",
            "precision": 4
        },
        {
            "fieldname": "column_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "wall_type",
            "fieldtype": "Select",
            "label": "Wall Type",
            "options": "Single Wall\nDouble Wall",
            "default": "Single Wall"
        },
        {
            "fieldname": "flute",
            "fieldtype": "Select",
            "label": "Flute",
            "options": "B\nC\nE\nBC\nEB",
            "default": "C"
        },
        {
            "fieldname": "quantity_needed",
            "fieldtype": "Int",
            "label": "Quantity Needed",
            "in_list_view": 1
        },
        {
            "fieldname": "num_colors",
            "fieldtype": "Int",
            "label": "Number of Colors",
            "default": "0"
        },
        {
            "fieldname": "coating",
            "fieldtype": "Select",
            "label": "Coating",
            "options": "None\nAqueous\nUV\nMatte",
            "default": "None"
        },
        {
            "fieldname": "section_details",
            "fieldtype": "Section Break",
            "label": "Details"
        },
        {
            "fieldname": "special_requirements",
            "fieldtype": "Text",
            "label": "Special Requirements"
        },
        {
            "fieldname": "artwork_file",
            "fieldtype": "Attach",
            "label": "Artwork File"
        },
        {
            "fieldname": "urgency",
            "fieldtype": "Select",
            "label": "Urgency",
            "options": "Standard\nRush\nEmergency",
            "default": "Standard"
        },
        {
            "fieldname": "section_internal",
            "fieldtype": "Section Break",
            "label": "Internal"
        },
        {
            "fieldname": "corrugated_estimate",
            "fieldtype": "Link",
            "label": "Corrugated Estimate",
            "options": "Corrugated Estimate",
            "read_only": 1
        },
        {
            "fieldname": "quoted_price",
            "fieldtype": "Currency",
            "label": "Quoted Price",
            "read_only": 1
        },
        {
            "fieldname": "notes",
            "fieldtype": "Text",
            "label": "Internal Notes"
        },
        {
            "fieldname": "amended_from",
            "fieldtype": "Link",
            "label": "Amended From",
            "options": "Quote Request",
            "read_only": 1,
            "no_copy": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "Sales User",
            "read": 1,
            "write": 1,
            "create": 1,
            "submit": 1,
            "cancel": 1
        }
    ],
    "sort_field": "modified",
    "sort_order": "DESC",
    "title_field": "customer"
}
